# PlatformIO build artifacts
firmware/.pio/
firmware/.vscode/

# Compiled output
*.o
*.elf
*.bin
*.hex

# macOS
.DS_Store
**/.DS_Store

# Temporarily gitignored CAD; final version will be published
cad/printing/**
!cad/printing/**/
!cad/printing/README.md
!cad/printing/**/.gitkeep
!cad/printing/**/*.md

# CAD swap files and autosave
*.~lock.*
*.bak

# Proprietary CAD source files (not useful without those tools)
*.SLDPRT
*.SLDASM
*.SLDDRW
*.ipt
*.iam
*.f3d

# Download archives and snapshot folders
*.zip
*snapshot*/

# OS screenshot artifacts (Cyrillic filenames from Windows/macOS screen captures)
*[сСнН]нимок*

# Excel temp files
~$*

# Logs (keep CSVs in docs/runs, not scattered elsewhere)
*.log

# Secrets / environment
.env

# Local developer notes and memory (not for repo)
CLAUDE.md
AGENTS.md
.claude/

# Downloaded conveyor reference prototypes (binary, not authored)
cad/frame/prototype*/

# Archived / superseded CAD parts (kept for rollback, not for build)
**/_archive/
